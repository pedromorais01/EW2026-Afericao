extends layout

block content
  .w3-card-4
    header.w3-container.w3-blue
      h1 Marca: #{brand}
    .w3-container
      h2 Modelos desta marca intervencionados:
      ul.w3-ul
        each m in models
          li= m
      
      h2 Registos de Reparação:
      table.w3-table-all
        tr
          th _id
          th data
          th nome
          th matrícula
          th marca
          th número de intervenções
        each r in list
          tr
            td
              a(href="/" + r._id)= r._id
            td= r.data
            td= r.nome
            td= r.viatura.matricula
            td
              a(href="/" + r.viatura.marca)= r.viatura.marca
            td= r.nr_intervencoes
            
    footer.w3-container.w3-blue
      address
        a(href="/") [Voltar à lista]
