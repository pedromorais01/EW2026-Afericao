extends layout

block content
  .w3-card-4
    header.w3-container.w3-blue
      h1 Registo de Reparação: #{r._id}
    .w3-container
      p
        b Nome: 
        | #{r.nome}
      p
        b NIF: 
        | #{r.nif}
      p
        b Data: 
        | #{r.data}
      p
        b Viatura: 
        | #{r.viatura.marca} #{r.viatura.modelo} (#{r.viatura.matricula})
      p
        b Número de Intervenções: 
        | #{r.nr_intervencoes}
      
      h2 Intervenções
      ul.w3-ul
        each i in r.intervencoes
          li
            b #{i.codigo} - #{i.nome}: 
            | #{i.descricao}
            
    footer.w3-container.w3-blue
      address
        a(href="/") [Voltar à lista]
